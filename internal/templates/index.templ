package templates

templ Index() {
	@Layout("Dashboard") {
		<h1>AuxiTalk Dashboard</h1>

		<div class="card">
			<h2>Status</h2>
			<p>Core is running</p>
			<p>Mode: dev</p>
		</div>

		<div class="card">
			<h2>Plugins</h2>
			<p>No plugins loaded yet.</p>
		</div>

		<div class="card">
			<h2>Sessions</h2>
			<p>No active sessions.</p>
		</div>
	}
}
