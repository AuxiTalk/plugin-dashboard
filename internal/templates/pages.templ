package templates

templ Sessions() {
	@Layout("Sessions") {
		<h1>Sessions</h1>
		<div class="card">
			<p>No active sessions.</p>
		</div>
	}
}

templ Events() {
	@Layout("Events") {
		<h1>Events</h1>
		<div class="card">
			<p>No events yet.</p>
		</div>
	}
}

templ Actions() {
	@Layout("Actions") {
		<h1>Actions</h1>
		<div class="card">
			<p>No pending actions.</p>
		</div>
	}
}
